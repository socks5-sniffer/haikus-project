<!DOCTYPE html>
<html>
  <head>
    <title>Haikus for Mona</title>
    <link href="/css/main.css" rel="stylesheet" type="text/css">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta property="og:title" content="Haikus for Mona">
    <meta property="og:description" content="Some of the best haikus you'll ever read about our rescue dog June">
    <meta property="og:image" content="/images/sunlight.jpg">
  </head>
  <body>
    <h1>socks5-sniffer haiku paradise</h1>
    
    <div class="main-container">
      <div class="left-section">
        <div class="haiku-generator">
          <h2>✨ Generate Your Own Haiku</h2>
          <p class="generator-subtitle">Enter a few words or a theme...</p>
          <div class="generator-form">
            <input type="text" id="userInput" placeholder="e.g., coding, coffee, debugging..." class="neon-input">
            <button onclick="generateHaiku()" class="neon-button">Generate Haiku</button>
          </div>
        </div>

        <div class="divider"></div>

        <h2 class="collection-title">📚 socks5-sniffer personal haiku</h2>

        <div class="original-haikus">
      <% for(var i=0; i < haikus.length; i++) { 
        const firstLine = haikus[i].text.split('\n')[0];
        const emojiMap = {
          'Cloudflare': '☁️',
          'JSON': '📄',
          'code': '💻',
          'computer': '🖥️',
          'npm': '📦',
          'Why': '🤔',
          'My': '🔧',
          'bug': '🐛',
          'cat': '🐱'
        };
        
        let emoji = '✨';
        for (const [keyword, icon] of Object.entries(emojiMap)) {
          if (firstLine.includes(keyword)) {
            emoji = icon;
            break;
          }
        }
      %>
        <div class="haiku-visual" style="background: linear-gradient(<%= 135 + (i * 30) %>deg, 
          hsl(<%= (i * 60) %>, 70%, 40%), 
          hsl(<%= (i * 60 + 40) %>, 60%, 30%));">
          <span><%= emoji %></span>
        </div>
        <div 
          class="haiku-containers">
          <p 
            class="haikus"
          ><%- haikus[i].text %></p>
        </div>
      <% } %>
        </div>
      </div>

      <div class="right-section">
        <h2 class="generated-title">✨ Your Generated Haikus</h2>
        <div id="generatedHaikusList" class="generated-haikus-grid"></div>
      </div>
    </div>

    <script>
      function capitalize(word) {
        return word.charAt(0).toUpperCase() + word.slice(1);
      }

      function createHaikuTile(selectedTemplate, mainWord) {
        const hue = Math.random() * 360;
        const tile = document.createElement('div');
        tile.className = 'generated-haiku-tile';
        tile.innerHTML = `
          <div class="tile-visual" style="background: linear-gradient(135deg, 
            hsl(${hue}, 70%, 40%), 
            hsl(${hue + 40}, 60%, 30%));">
            <span>${selectedTemplate.emoji}</span>
          </div>
          <div class="tile-haiku">
            <p class="tile-text">${selectedTemplate.lines.join('<br>')}</p>
          </div>
          <button class="tile-delete" onclick="deleteTile(this)" title="Delete">×</button>
        `;
        return tile;
      }

      function deleteTile(button) {
        const tile = button.closest('.generated-haiku-tile');
        tile.style.animation = 'fadeOut 0.3s ease-out';
        setTimeout(() => tile.remove(), 300);
      }

      function generateHaiku() {
        const input = document.getElementById('userInput').value.trim();
        if (!input) {
          alert('Please enter some words!');
          return;
        }

        const words = input.toLowerCase().split(/[\s,]+/);
        const mainWord = words[0];

        // Haiku templates with 5-7-5 syllable structure
        const templates = [
          {
            lines: [
              `${capitalize(mainWord)} in the morning light`,
              `Silent whispers of the code`,
              `Dreams become alive`
            ],
            emoji: '🌅'
          },
          {
            lines: [
              `${capitalize(mainWord)} calls my name softly`,
              `Through the digital expanse`,
              `I find my purpose`
            ],
            emoji: '💻'
          },
          {
            lines: [
              `Bits and bytes of ${mainWord}`,
              `Dancing across my screen now`,
              `Logic finds its way`
            ],
            emoji: '✨'
          },
          {
            lines: [
              `${capitalize(mainWord)} brings me peace`,
              `In this world of endless loops`,
              `I finally rest`
            ],
            emoji: '🌙'
          },
          {
            lines: [
              `Late night ${mainWord} session`,
              `Coffee cooling by my side`,
              `One more line to write`
            ],
            emoji: '☕'
          },
          {
            lines: [
              `${capitalize(mainWord)} flows like water`,
              `Through the pathways of my mind`,
              `Creating something new`
            ],
            emoji: '💧'
          },
          {
            lines: [
              `Debug ${mainWord} again`,
              `Stack trace leading nowhere now`,
              `Tomorrow is fresh`
            ],
            emoji: '🐛'
          },
          {
            lines: [
              `${capitalize(mainWord)} compiles at last`,
              `Green checkmarks fill up my screen`,
              `Victory is sweet`
            ],
            emoji: '✅'
          }
        ];

        const selectedTemplate = templates[Math.floor(Math.random() * templates.length)];
        
        const listDiv = document.getElementById('generatedHaikusList');
        const tile = createHaikuTile(selectedTemplate, mainWord);
        
        // Add to the top of the list
        listDiv.insertBefore(tile, listDiv.firstChild);
        
        // Clear input
        document.getElementById('userInput').value = '';
        
        // Scroll the new tile into view
        setTimeout(() => {
          tile.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }, 100);
      }

      // Allow Enter key to generate
      document.addEventListener('DOMContentLoaded', function() {
        const input = document.getElementById('userInput');
        if (input) {
          input.addEventListener('keypress', function(e) {
            if (e.key === 'Enter') {
              generateHaiku();
            }
          });
        }
      });
    </script>
</html>
